FROM mcr.microsoft.com/devcontainers/python:3.11

RUN apt-get update && \
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh && \
    bash Miniconda3-latest-Linux-x86_64.sh -b -p /opt/conda && \
    rm Miniconda3-latest-Linux-x86_64.sh && \
    apt-get clean

ENV PATH=/opt/conda/bin:$PATH
RUN conda config --set auto_update_conda false && \
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main && \
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r


WORKDIR /app
COPY biomni_env/environment.yml .

RUN conda env create -f environment.yml

RUN wget -q https://cdn-media.huggingface.co/frpc-gradio-0.2/frpc_linux_amd64 -O /opt/conda/envs/biomni_e1/lib/python3.11/site-packages/gradio/frpc_linux_amd64_v0.2 && \
    chmod +x /opt/conda/envs/biomni_e1/lib/python3.11/site-packages/gradio/frpc_linux_amd64_v0.2

RUN mkdir /home/hf_cache

ENV HF_HOME=/home/hf_cache

RUN conda clean -a -y && echo "Conda cache cleaned."

SHELL ["conda", "run", "-n", "biomni_e1", "/bin/bash", "-c"]
COPY app ./app
COPY start.sh ./start.sh
RUN chmod +x ./start.sh

ARG HATZ_API_KEY
ENV HATZ_API_KEY=$HATZ_API_KEY

RUN python -c "from biomni.agent.a1 import A1; import os; \
    try: \
        A1(llm='gpt-4.1-mini', api_key=os.environ['HATZ_API_KEY'], base_url='https://ai.hatz.ai/v1', timeout_seconds=600, use_tool_retriever=True, path='./data'); \
    except Exception as e: \
        print('A1 init raised (expected for build-only download):', e); \
    print('Data lake download complete')"

EXPOSE 7860
CMD ["conda", "run", "-n", "biomni_e1", "python", "-m", "app.gradio_app"]
